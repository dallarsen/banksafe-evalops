# Copy this file to `.env` and fill in your real values.
# `.env` is gitignored — never commit real keys.

# --- LLM Provider (Anthropic API direct) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Model configuration ---
AGENT_MODEL=claude-sonnet-4-5
JUDGE_PRIMARY_MODEL=claude-sonnet-4-5
JUDGE_SECONDARY_MODEL=claude-haiku-4-5

# --- MLflow tracking ---
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=banksafe-compliance-agent

# --- Eval thresholds (CI gating) ---
EVAL_REGRESSION_THRESHOLD=0.05
EVAL_FAIL_ON_PII_LEAK=true
EVAL_FAIL_ON_HALLUCINATION_RATE=0.10
